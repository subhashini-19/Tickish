PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=

# Azure Entra External ID
AZURE_TENANT_ID=
AZURE_TENANT_DOMAIN=        # e.g. todoappusers.ciamlogin.com (from well-known OIDC config)
AZURE_API_CLIENT_ID=

# Azure Application Insights (optional for local dev)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Elasticsearch (Elastic Cloud)
ELASTICSEARCH_NODE=
ELASTICSEARCH_API_KEY=
